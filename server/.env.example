PORT=5000
# Local MongoDB:
# MONGO_URI=mongodb://127.0.0.1:27017/leadgen
#
# Atlas: wrap in quotes. Encode # as %23 and @ in password as %40 — never use raw # in .env!
# MONGO_URI="mongodb://USER:PASS%40%23123@host1:27017,host2:27017/leadgen?ssl=true&authSource=admin"
JWT_SECRET=your_super_secret_jwt_key_change_in_production
# Local: http://localhost:5173 | Production (Railway): https://your-app.vercel.app
CLIENT_URL=http://localhost:5173
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
