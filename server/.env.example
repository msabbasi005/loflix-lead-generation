PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/leadgen
# Atlas: use "Drivers" connection string. If seed fails with querySrv ECONNREFUSED,
# use the standard mongodb://... URI (not mongodb+srv://) from Atlas → Connect.
JWT_SECRET=your_super_secret_jwt_key_change_in_production
# Local: http://localhost:5173 | Production (Railway): https://your-app.vercel.app
CLIENT_URL=http://localhost:5173
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
